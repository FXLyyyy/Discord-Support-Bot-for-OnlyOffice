# ============================================================================
#  Copy this file to .env and fill in the values, then: docker compose up -d
# ============================================================================

# ---- Discord ----
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_client_id_here
# Optional: register slash commands to ONE guild instantly (great for testing).
# Leave empty to register globally (can take up to ~1h to appear).
DISCORD_GUILD_ID=

# ---- Postgres (used by BOTH the database container and the bot) ----
POSTGRES_USER=ootickets
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=ootickets
# In docker compose the bot reaches the DB automatically (host "postgres").
# For running WITHOUT docker, point the bot at your own Postgres instead:
# DATABASE_URL=postgres://ootickets:password@localhost:5432/ootickets

# ---- DocSpace (transcript storage) — optional ----
# Leave blank to fall back to attaching the HTML transcript file in Discord.
DOCSPACE_BASE_URL=https://your-instance.onlyoffice.com
DOCSPACE_API_KEY=your_docspace_api_key_here
DOCSPACE_TRANSCRIPTS_FOLDER_ID=your_folder_or_room_id_here

# Database backup to DocSpace: how often (hours). 0 disables. Requires DocSpace.
BACKUP_INTERVAL_HOURS=24

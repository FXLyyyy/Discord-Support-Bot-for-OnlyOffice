{
  "name": "discord-support-bot",
  "version": "1.0.0",
  "description": "Self-hosted Discord support bot for OnlyOffice (tickets, transcripts, DocSpace)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts"
  },
  "dependencies": {
    "discord.js": "^14.14.1",
    "docx": "^9.7.1",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/pg": "^8.20.0",
    "tsx": "^4.22.4",
    "typescript": "^5.3.3"
  }
}
